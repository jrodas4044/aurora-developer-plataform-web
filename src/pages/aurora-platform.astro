---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import Glow from '../components/Glow.astro';
import CrossLinks from '../components/CrossLinks.astro';
import CtaBand from '../components/CtaBand.astro';
import IsoTowerThree from '../components/IsoTowerThree.astro';
import { platform } from '../data/product';

const { hero, sections, cta, crossLinks } = platform;
---

<BaseLayout title={platform.metaTitle} description={platform.metaDescription}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <Glow class="left-1/2 top-[-6rem] h-[28rem] w-[44rem] -translate-x-1/2" />
    <Container wide class="relative py-24 sm:py-32">
      <div class="grid items-center gap-x-12 gap-y-12 lg:grid-cols-12">
        <div class="lg:col-span-6">
          <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">{hero.eyebrow}</p>
          <h1 class="mt-5 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
            {hero.h1}
          </h1>
          <p class="mt-6 text-xl font-medium text-gradient sm:text-2xl">{hero.sub}</p>
          <p class="mt-4 max-w-xl text-pretty leading-relaxed text-fg-2">{hero.lede}</p>
          <div class="mt-9 flex flex-wrap gap-3">
            <Button href={hero.primary.href} variant="primary" size="lg">{hero.primary.label}</Button>
            <Button href={hero.secondary.href} variant="secondary" size="lg">{hero.secondary.label}</Button>
          </div>
        </div>

        <!-- Torre isométrica 3D (Three.js): la UI se monta sobre Aurora, y Aurora sobre el GL. -->
        <div class="lg:col-span-6">
          <IsoTowerThree />
          <p class="mt-2 text-center font-mono text-[11px] text-fg-3">tú construyes en la capa del medio</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Tesis + comparativa -->
  {
    sections.map((s) => (
      <section class="border-t border-line py-20 sm:py-28">
        <Container wide>
          <div class="space-y-8">
            <div class="max-w-2xl">
              <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">{s.eyebrow}</p>
              <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">{s.heading}</h2>
            </div>
            <div class="min-w-0 space-y-6">
              {s.kind === 'comparison' && s.rows && (
                <div>
                  {/* Desktop: matriz */}
                  <div class="hidden overflow-hidden rounded-xl border border-line md:block">
                    <table class="w-full text-left text-sm">
                      <thead>
                        <tr class="border-b border-line bg-panel">
                          <th class="px-4 py-3 font-medium text-fg-3" />
                          {s.competitors.map((c) => (
                            <th class="px-4 py-3 font-medium text-fg-2">{c}</th>
                          ))}
                          <th class="bg-panel-2 px-4 py-3 font-semibold text-fg">Aurora</th>
                        </tr>
                      </thead>
                      <tbody>
                        {s.rows.map((r) => (
                          <tr class="border-b border-line last:border-0">
                            <td class="px-4 py-3 font-medium text-fg">{r.dim}</td>
                            {r.cells.map((c) => (
                              <td class="px-4 py-3 text-fg-3">{c}</td>
                            ))}
                            <td class="bg-panel-2 px-4 py-3 font-medium text-fg">{r.aurora}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                  {/* Móvil: una card por dimensión (sin scroll horizontal) */}
                  <div class="space-y-4 md:hidden">
                    {s.rows.map((r) => (
                      <div class="rounded-xl border border-line bg-panel p-4">
                        <p class="font-medium text-fg">{r.dim}</p>
                        <div class="mt-3 rounded-lg border border-brand/40 bg-ink-2 px-3 py-2">
                          <span class="font-mono text-[11px] uppercase tracking-widest text-fg-3">Aurora</span>
                          <p class="mt-0.5 text-sm text-fg">{r.aurora}</p>
                        </div>
                        <dl class="mt-3 space-y-1.5 text-sm">
                          {s.competitors.map((c, i) => (
                            <div class="flex justify-between gap-3">
                              <dt class="text-fg-3">{c}</dt>
                              <dd class="text-right text-fg-2">{r.cells[i]}</dd>
                            </div>
                          ))}
                        </dl>
                      </div>
                    ))}
                  </div>
                  {s.note && <p class="mt-4 max-w-2xl text-[13px] leading-relaxed text-fg-3">{s.note}</p>}
                </div>
              )}
              {s.body && <p class="max-w-3xl text-pretty leading-relaxed text-fg-2">{s.body}</p>}
              {s.bullets && (
                <ul class="grid gap-2 sm:grid-cols-2">
                  {s.bullets.map((b) => (
                    <li class="rounded-lg border border-line bg-panel px-4 py-3 text-fg-2">{b}</li>
                  ))}
                </ul>
              )}
              {s.close && <p class="text-xl font-medium text-gradient">{s.close}</p>}
            </div>
          </div>
        </Container>
      </section>
    ))
  }

  <CrossLinks links={crossLinks} heading="Las capas de la plataforma" />
  <CtaBand heading={cta.heading} body={cta.body} primary={cta.primary} secondary={cta.secondary} />
</BaseLayout>
