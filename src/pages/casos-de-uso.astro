---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import PageHeader from '../components/PageHeader.astro';
import CrossLinks from '../components/CrossLinks.astro';
import CtaBand from '../components/CtaBand.astro';
import { casos } from '../data/pages';

const capLinks = [
  { label: 'Aurora Make', href: '/aurora-make', blurb: 'Cómo se genera cada uno de estos módulos.' },
  { label: 'Aurora Platform SDK', href: '/aurora-platform-sdk', blurb: 'Los contratos por los que postean sin tocar el kernel.' },
  { label: 'Aurora Runtime', href: '/aurora-runtime', blurb: 'La multiempresa e infraestructura que reusan.' },
  { label: 'Aurora Architecture', href: '/aurora-architecture', blurb: 'Las reglas que mantienen la integridad.' },
];
---

<BaseLayout title={casos.metaTitle} description={casos.metaDescription}>
  <PageHeader eyebrow={casos.heroEyebrow} title={casos.heroH1} lede={casos.heroLede} />

  <Container class="py-16 sm:py-20">
    <p class="max-w-3xl text-pretty leading-relaxed text-fg-2">{casos.intro}</p>

    <div class="mt-12 grid gap-4 sm:mt-16 sm:grid-cols-2">
      {
        casos.cases.map((c) => (
          <article class="flex flex-col rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2">
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-[17px] font-semibold text-fg">{c.title}</h2>
              {c.mono && <span class="shrink-0 font-mono text-[11px] text-accent">{c.mono}</span>}
            </div>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-fg-2">{c.body}</p>
            <p class="mt-5 inline-flex w-fit rounded-full border border-line bg-ink-2 px-3 py-1 font-mono text-[11px] text-fg-3">
              {c.status}
            </p>
          </article>
        ))
      }
    </div>
  </Container>

  <section class="border-y border-line bg-ink-2">
    <Container class="py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Por qué Aurora</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">{casos.why.heading}</h2>
      </div>
      <ul class="mt-10 grid gap-x-10 gap-y-6 lg:grid-cols-2">
        {
          casos.why.points.map((point) => (
            <li class="flex items-start gap-3 text-pretty leading-relaxed text-fg-2">
              <svg
                width="18"
                height="18"
                viewBox="0 0 18 18"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mt-1 shrink-0 text-accent"
                aria-hidden="true"
              >
                <circle cx="9" cy="9" r="7.5" class="opacity-40" />
                <path d="m5.75 9.25 2.25 2.25 4.25-4.75" />
              </svg>
              {point}
            </li>
          ))
        }
      </ul>
    </Container>
  </section>

  <CrossLinks links={capLinks} heading="Las capacidades detrás de estos sistemas" />
  <CtaBand heading={casos.cta.heading} body={casos.cta.body} primary={casos.cta.primary} secondary={casos.cta.secondary} />
</BaseLayout>
