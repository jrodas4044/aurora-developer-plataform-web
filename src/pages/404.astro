---
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import Glow from '../components/Glow.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Aurora Labs" description="The page you're looking for doesn't exist.">
  <section class="relative overflow-hidden">
    <Glow class="left-1/2 top-[-120px] h-[360px] w-[640px] -translate-x-1/2" />
    <Container class="relative flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">404</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-tight sm:text-6xl">
        <span class="text-gradient">Lost</span> in space
      </h1>
      <p class="mt-5 max-w-md text-pretty text-lg leading-relaxed text-fg-2">
        This page doesn't exist — or it was deployed to a region we haven't heard back from yet.
      </p>
      <div class="mt-8 flex gap-3">
        <Button href="/">Back home</Button>
        <Button href="/blog/" variant="secondary">Read the blog</Button>
      </div>
    </Container>
  </section>
</BaseLayout>
