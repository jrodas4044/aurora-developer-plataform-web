---
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import Glow from '../components/Glow.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada — Aurora" description="La página que busca no existe.">
  <section class="relative overflow-hidden">
    <Glow class="left-1/2 top-[-120px] h-[360px] w-[640px] -translate-x-1/2" />
    <Container class="relative flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">404</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-tight sm:text-6xl">
        Página <span class="text-gradient">no encontrada</span>
      </h1>
      <p class="mt-5 max-w-md text-pretty text-lg leading-relaxed text-fg-2">
        La página que busca no existe o cambió de dirección.
      </p>
      <div class="mt-8 flex gap-3">
        <Button href="/">Volver al inicio</Button>
      </div>
    </Container>
  </section>
</BaseLayout>
