---
import { Code } from 'astro:components';
import codeTheme from '@shikijs/themes/catppuccin-mocha';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import WindowDots from '../components/WindowDots.astro';
import PageHeader from '../components/PageHeader.astro';
import CrossLinks from '../components/CrossLinks.astro';
import CtaBand from '../components/CtaBand.astro';
import { loop } from '../data/pages';

const capLinks = [
  { label: 'Aurora Make', href: '/aurora-make', blurb: 'El manifiesto y el generador detrás del paso 1.' },
  { label: 'Aurora Platform SDK', href: '/aurora-platform-sdk', blurb: 'Los contratos estables del paso 2.' },
  { label: 'Aurora Runtime', href: '/aurora-runtime', blurb: 'El descubrimiento y la multiempresa del paso 3.' },
  { label: 'Aurora Architecture', href: '/aurora-architecture', blurb: 'Las fitness functions del paso 4, a fondo.' },
];
---

<BaseLayout title={loop.metaTitle} description={loop.metaDescription}>
  <PageHeader eyebrow={loop.heroEyebrow} title={loop.heroH1} lede={loop.heroLede} />

  <Container class="py-16 sm:py-20">
    <p class="max-w-3xl text-pretty leading-relaxed text-fg-2">{loop.intro}</p>

    <div class="mt-12 space-y-12 sm:mt-16 sm:space-y-16">
      {
        loop.steps.map((step) => (
          <div class="grid items-start gap-8 border-t border-line pt-10 lg:grid-cols-2 lg:gap-12">
            <div>
              <span class="font-mono text-sm text-accent">{step.n}</span>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-fg sm:text-[28px]">{step.title}</h2>
              <p class="mt-4 max-w-xl text-pretty leading-relaxed text-fg-2">{step.body}</p>
            </div>
            <div class="min-w-0">
              <div class="glass overflow-hidden rounded-xl shadow-2xl shadow-black/40">
                <div class="flex items-center gap-2 border-b border-line px-4 py-3">
                  <WindowDots />
                  <span class="ml-3 truncate font-mono text-xs text-fg-3">{step.code.label}</span>
                </div>
                <div class="overflow-x-auto p-4 text-left text-[13px]">
                  <Code code={step.code.content} lang={step.code.lang} theme={codeTheme} />
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>

  <section class="border-y border-line bg-ink-2">
    <Container class="py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Verificación</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">{loop.verification.heading}</h2>
        <p class="mt-4 max-w-xl text-fg-2">{loop.verification.lede}</p>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {
          loop.verification.checks.map((c) => (
            <div class="rounded-xl border border-line bg-panel p-5">
              <p class="flex items-center gap-2 font-mono text-[13px] text-fg">
                <span class="text-accent" aria-hidden="true">✓</span>
                {c.label}
              </p>
              <p class="mt-2 text-sm leading-relaxed text-fg-2">{c.detail}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <CrossLinks links={capLinks} heading="Las cuatro capacidades del loop" />
  <CtaBand heading={loop.cta.heading} body={loop.cta.body} primary={loop.cta.primary} secondary={loop.cta.secondary} />
</BaseLayout>
