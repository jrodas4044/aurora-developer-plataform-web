---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/home/CTA.astro';
import Features from '../components/home/Features.astro';
import Hero from '../components/home/Hero.astro';
import CrossLinks from '../components/CrossLinks.astro';

const explore = [
  {
    label: 'Cómo funciona',
    href: '/como-funciona',
    blurb: 'El loop completo en código real: del manifiesto al módulo registrado y verificado en CI.',
  },
  {
    label: 'Casos de uso',
    href: '/casos-de-uso',
    blurb: 'Qué se construye sobre Aurora: ERP y gestión financiera, ventas, inventario, CRM, nómina, analítica.',
  },
  {
    label: 'Blog',
    href: '/blog/',
    blurb: 'Notas de la plataforma: ADRs, contratos del SDK y módulos nuevos.',
  },
];
---

<BaseLayout
  title="Aurora Labs — Software de gestión empresarial y finanzas para LATAM"
  description="Aurora Labs es la plataforma para construir software de gestión empresarial, control de finanzas y fiscal sobre un kernel financiero verificable. ERP, multiempresa y módulos para empresas de Latinoamérica."
>
  <Hero />
  <Features />
  <CrossLinks links={explore} heading="Explore la plataforma" />
  <CTA />
</BaseLayout>
