---
import BaseLayout from '../layouts/BaseLayout.astro';
import CapabilityPage from '../components/CapabilityPage.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import Glow from '../components/Glow.astro';
import WindowDots from '../components/WindowDots.astro';
import { datos } from '../data/product';

// Campos que Aurora extrae del DTE, ya normalizados.
const campos = [
  { k: 'Tercero', v: 'Distribuidora El Quetzal' },
  { k: 'Fecha', v: '27 jun 2026' },
  { k: 'Monto', v: 'Q 8,750' },
  { k: 'IVA', v: 'Q 938' },
];
---

<BaseLayout title={datos.metaTitle} description={datos.metaDescription}>
  <CapabilityPage data={datos}>
    <section slot="hero" class="relative overflow-hidden border-b border-line">
      <Glow class="left-1/2 top-[-8rem] h-[30rem] w-[46rem] -translate-x-1/2" />
      <Container wide class="relative py-20 sm:py-28">
        <div class="grid items-center gap-x-12 gap-y-12 lg:grid-cols-12">
          <div class="lg:col-span-6">
            <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">{datos.heroEyebrow}</p>
            <h1 class="mt-5 text-balance text-4xl font-semibold leading-[1.1] tracking-tight sm:text-5xl">
              {datos.heroH1}
            </h1>
            <p class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">{datos.heroLede}</p>
            <div class="mt-9 flex flex-wrap gap-3">
              <Button href={datos.cta.primary.href} variant="primary" size="lg">{datos.cta.primary.label}</Button>
              <Button href={datos.cta.secondary.href} variant="secondary" size="lg">{datos.cta.secondary.label}</Button>
            </div>
          </div>

          <!-- El DTE llega estructurado → se normaliza → se propone el asiento -->
          <div class="lg:col-span-6">
            <div class="di-card glass relative mx-auto max-w-md overflow-hidden rounded-xl shadow-card-lg">
              <div class="flex items-center gap-2 border-b border-line px-4 py-3">
                <WindowDots />
                <span class="ml-3 font-mono text-xs text-fg-3">ingesta · FEL/SAT</span>
                <span class="ml-auto flex items-center gap-1.5 font-mono text-[11px] text-accent">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_8px_rgb(47_77_102/0.8)]"></span>
                  estructurado
                </span>
              </div>

              <div class="space-y-3 p-4">
                <!-- El documento llega ya estructurado desde la autoridad fiscal -->
                <div class="di-doc flex items-center gap-2.5 rounded-lg border border-line bg-panel px-3.5 py-2.5">
                  <span class="flex h-7 w-7 items-center justify-center rounded-md bg-panel-2 text-[13px]">🧾</span>
                  <div class="min-w-0">
                    <p class="text-[13px] text-fg">DTE recibido</p>
                    <p class="font-mono text-[11px] text-fg-3">FEL · 2C9A-…-4F1</p>
                  </div>
                  <span class="ml-auto rounded-full border border-line bg-panel px-2 py-0.5 font-mono text-[10px] text-accent">SAT</span>
                </div>

                <!-- Aurora normaliza el documento en datos -->
                <div class="di-fields grid grid-cols-2 gap-2">
                  {
                    campos.map((c) => (
                      <div class="rounded-lg border border-line bg-ink-2/50 px-3 py-2">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-fg-3">{c.k}</p>
                        <p class="mt-0.5 truncate text-[12px] text-fg-2">{c.v}</p>
                      </div>
                    ))
                  }
                </div>

                <!-- Asiento propuesto a partir del DTE -->
                <div class="di-prop rounded-lg border border-brand/30 bg-ink-2/70 p-3">
                  <p class="text-[12px] text-fg-2">
                    <span class="font-mono text-[11px] uppercase tracking-widest text-brand-bright">Propone</span>
                    · registrar a <span class="text-fg">Compras · Mercadería</span>
                  </p>
                  <p class="mt-1 text-[11px] text-fg-3">↳ cuenta sugerida por el histórico del proveedor</p>
                  <div class="mt-2.5 flex gap-2">
                    <span class="di-cta rounded-md bg-gradient-to-r from-brand to-accent px-3 py-1 text-[12px] font-medium text-ink">✓ Aprobar</span>
                    <span class="rounded-md border border-line px-3 py-1 text-[12px] text-fg-2">Editar</span>
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-2 border-t border-line bg-ink-2/60 px-4 py-3 font-mono text-[11px] text-fg-3">
                <span class="h-1.5 w-1.5 rounded-full bg-brand"></span>
                del DTE al asiento, sin captura manual
              </div>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </CapabilityPage>
</BaseLayout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .di-doc {
      opacity: 0;
      animation: di-rise 0.5s var(--ease-out-soft) both;
      animation-delay: 0.3s;
    }
    .di-fields > div {
      opacity: 0;
      animation: di-rise 0.5s var(--ease-out-soft) both;
    }
    .di-fields > div:nth-child(1) {
      animation-delay: 0.8s;
    }
    .di-fields > div:nth-child(2) {
      animation-delay: 0.95s;
    }
    .di-fields > div:nth-child(3) {
      animation-delay: 1.1s;
    }
    .di-fields > div:nth-child(4) {
      animation-delay: 1.25s;
    }
    .di-prop {
      opacity: 0;
      animation: di-rise 0.5s var(--ease-out-soft) both;
      animation-delay: 1.6s;
    }
    .di-cta {
      animation: di-pulse 1.8s var(--ease-out-soft) 2s 2;
    }
  }

  @keyframes di-rise {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes di-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgb(152 54 74 / 0);
    }
    50% {
      box-shadow: 0 0 0 4px rgb(152 54 74 / 0.25);
    }
  }
</style>
