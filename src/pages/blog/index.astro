---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Container from '../../components/Container.astro';
import Glow from '../../components/Glow.astro';
import Avatar from '../../components/blog/Avatar.astro';
import PostCard from '../../components/blog/PostCard.astro';
import TagPill from '../../components/blog/TagPill.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;

const featuredDate = featured.data.pubDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout
  title="Blog — Aurora Labs"
  description="Engineering deep-dives, release notes, and the decisions behind Aurora Labs — written by the people who ship it."
>
  <section class="relative overflow-hidden">
    <Glow class="left-1/2 top-[-220px] h-[440px] w-[780px] -translate-x-1/2" />

    <Container class="relative pb-20 pt-16 sm:pb-28 sm:pt-24">
      <header class="max-w-2xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Blog</p>
        <h1 class="mt-3 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
          Notes from the <span class="text-gradient">edge</span>
        </h1>
        <p class="mt-4 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">
          Engineering deep-dives, release notes, and the decisions behind Aurora Labs — written by the
          people who ship it.
        </p>
      </header>

      {
        featured && (
          <article class="group relative mt-14 overflow-hidden rounded-xl border border-line bg-panel p-8 transition-colors duration-200 hover:border-line-2 hover:bg-panel-2 sm:p-10">
            <div class="flex flex-wrap items-center gap-2.5">
              <span class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-wider text-accent">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_8px_rgb(34_211_238/0.8)]" />
                Latest
              </span>
              {featured.data.tags.map((tag) => (
                <TagPill>{tag}</TagPill>
              ))}
            </div>

            <h2 class="mt-5 max-w-3xl text-balance text-2xl font-semibold leading-tight tracking-tight text-fg sm:text-3xl">
              <a
                href={`/blog/${featured.id}/`}
                class="rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand"
              >
                <span class="absolute inset-0 z-10" aria-hidden="true" />
                {featured.data.title}
              </a>
            </h2>

            <p class="mt-4 max-w-2xl text-pretty leading-relaxed text-fg-2">
              {featured.data.description}
            </p>

            <div class="mt-8 flex flex-wrap items-center justify-between gap-4">
              <div class="flex items-center gap-3">
                <Avatar name={featured.data.author} size="md" />
                <div class="text-[13px] leading-tight">
                  <p class="text-fg">{featured.data.author}</p>
                  <p class="mt-0.5 text-fg-3">
                    {featured.data.authorRole && <span>{featured.data.authorRole} · </span>}
                    <time datetime={featured.data.pubDate.toISOString()}>{featuredDate}</time>
                  </p>
                </div>
              </div>
              <p class="flex items-center gap-1.5 text-sm font-medium text-fg-2 transition-colors group-hover:text-fg">
                Read post
                <span
                  aria-hidden="true"
                  class="transition-transform duration-200 group-hover:translate-x-0.5"
                >
                  →
                </span>
              </p>
            </div>
          </article>
        )
      }

      {
        rest.length > 0 && (
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        )
      }

      <aside
        aria-label="Upgrade to Pulsar"
        class="glass mt-16 flex flex-col items-start justify-between gap-5 rounded-xl p-6 sm:flex-row sm:items-center sm:p-7"
      >
        <div>
          <p class="text-sm font-medium text-fg">Need docs, changelog, and pricing pages?</p>
          <p class="mt-1.5 max-w-md text-sm leading-relaxed text-fg-2">
            Pulsar — the full theme — adds restyled Starlight docs, a pricing page, and a
            changelog to everything in Lite. $39, with 12 months of updates.
          </p>
        </div>
        <Button
          href="https://buy.cometthemes.com"
          variant="secondary"
          size="sm"
          class="shrink-0"
        >
          Get Pulsar
        </Button>
      </aside>
    </Container>
  </section>
</BaseLayout>
