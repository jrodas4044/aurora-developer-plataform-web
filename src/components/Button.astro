---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}
const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand';

const variants = {
  primary:
    'bg-gradient-to-r from-brand to-accent text-ink shadow-glow hover:brightness-110 active:brightness-95',
  secondary:
    'bg-panel text-fg border border-line hover:border-line-2 hover:bg-panel-2',
  ghost: 'text-fg-2 hover:text-fg',
};

const sizes = {
  sm: 'h-8 px-3 text-sm',
  md: 'h-10 px-4 text-sm',
  lg: 'h-12 px-6 text-base',
};
---

<a href={href} class={`${base} ${variants[variant]} ${sizes[size]} ${className}`}>
  <slot />
</a>
