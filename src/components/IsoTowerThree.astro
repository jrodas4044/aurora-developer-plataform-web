---
// Torre isométrica de capas (Kernel → Aurora → UI + capabilities) renderizada
// con Three.js como isla client de Astro. Reemplaza la versión CSS hecha a mano:
// luces reales, sombra de contacto, float idle y parallax al puntero.
---

<div class="iso3d" data-iso3d>
  <canvas data-iso3d-canvas></canvas>
</div>

<script>
  import * as THREE from 'three';
  import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js';

  // Re-init on every View Transitions navigation (script runs once; this fires per page).
  document.addEventListener('astro:page-load', () => {
    const mount = document.querySelector('[data-iso3d]') as HTMLElement | null;
    const canvas = document.querySelector('[data-iso3d-canvas]') as HTMLCanvasElement | null;
    if (mount && canvas && !mount.dataset.iso3dReady) {
      mount.dataset.iso3dReady = '1';
      initTower(mount, canvas);
    }
  });

  function initTower(mount: HTMLElement, canvas: HTMLCanvasElement) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFShadowMap;
    // @ts-ignore — outputColorSpace existe en three >=0.152
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.0;

    const scene = new THREE.Scene();

    // Environment map suave (reflejos premium en los materiales).
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    let w = mount.clientWidth;
    let h = mount.clientHeight;
    const frustum = 5.0;
    const camera = new THREE.OrthographicCamera(0, 0, 0, 0, -50, 100);
    camera.position.set(6, 5, 6);
    camera.lookAt(0, 0, 0);

    function setSize() {
      w = mount.clientWidth;
      h = mount.clientHeight;
      const aspect = w / h;
      camera.left = (-frustum * aspect) / 2;
      camera.right = (frustum * aspect) / 2;
      camera.top = frustum / 2;
      camera.bottom = -frustum / 2;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h, false);
    }
    setSize();

    // ── Luces ──────────────────────────────────────────────
    scene.add(new THREE.HemisphereLight(0xffffff, 0xc2cad6, 0.85));
    const key = new THREE.DirectionalLight(0xffffff, 1.45);
    key.position.set(4.5, 9, 4);
    key.castShadow = true;
    key.shadow.mapSize.set(2048, 2048);
    key.shadow.radius = 6;
    key.shadow.bias = -0.0006;
    const sc = key.shadow.camera;
    sc.left = -5;
    sc.right = 5;
    sc.top = 5;
    sc.bottom = -5;
    sc.near = 0.5;
    sc.far = 30;
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xffffff, 0.4);
    fill.position.set(-6, 4, -3);
    scene.add(fill);
    // Rim trasera: define los bordes contra el fondo claro.
    const rim = new THREE.DirectionalLight(0xdfe6f0, 0.55);
    rim.position.set(-3, 5, -7);
    scene.add(rim);

    // ── Etiqueta horneada en una cara (CanvasTexture) ──────
    // El canvas usa el MISMO aspect que la cara (ancho/alto) → texto sin estirar.
    function labelTexture(label: string, sub: string, bg: string, fg: string, aspect: number, big = false) {
      const H = 320;
      const W = Math.round(H * aspect);
      const c = document.createElement('canvas');
      c.width = W;
      c.height = H;
      const ctx = c.getContext('2d')!;
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = fg;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      const pad = W * 0.78; // margen: evita que el texto toque los bordes de la cara
      ctx.font = `600 ${Math.round(H * (big ? 0.28 : 0.22))}px "Space Grotesk Variable", Inter, sans-serif`;
      ctx.fillText(label, W / 2, sub ? H * 0.42 : H * 0.5, pad);
      if (sub) {
        ctx.globalAlpha = 0.62;
        ctx.font = `500 ${Math.round(H * 0.095)}px "IBM Plex Mono", monospace`;
        ctx.letterSpacing = '2px';
        ctx.fillText(sub, W / 2, H * 0.64, pad);
      }
      const tex = new THREE.CanvasTexture(c);
      // @ts-ignore
      tex.colorSpace = THREE.SRGBColorSpace;
      tex.anisotropy = renderer.capabilities.getMaxAnisotropy();
      return tex;
    }

    // material array por caras: [+X,-X,+Y,-Y,+Z,-Z]. Etiqueta en +Z y +X.
    function faceMaterials(color: number, rough: number, tex?: THREE.Texture, emissive = 0x000000) {
      const base = () =>
        new THREE.MeshStandardMaterial({ color, roughness: rough, metalness: 0.12, envMapIntensity: 0.7, emissive });
      const labeled = () =>
        tex
          ? new THREE.MeshStandardMaterial({
              color: 0xffffff,
              map: tex,
              roughness: rough,
              metalness: 0.12,
              envMapIntensity: 0.7,
              emissive,
              emissiveMap: tex,
              emissiveIntensity: emissive ? 0.25 : 0,
            })
          : base();
      return [labeled(), base(), base(), base(), labeled(), base()];
    }

    function slab(
      wd: number,
      ht: number,
      dp: number,
      y: number,
      color: number,
      rough: number,
      tex?: THREE.Texture,
      emissive = 0x000000,
    ) {
      const m = new THREE.Mesh(new THREE.BoxGeometry(wd, ht, dp), faceMaterials(color, rough, tex, emissive));
      m.position.y = y;
      m.castShadow = true;
      m.receiveShadow = true;
      group.add(m);
      return m;
    }

    const group = new THREE.Group();
    scene.add(group);

    // Geometría (Y arriba). De abajo a arriba: Laravel → Kernel → Aurora → UI → capabilities.
    const blocks: { m: THREE.Mesh; y: number; delay: number }[] = [];
    const add = (m: THREE.Mesh, y: number, delay: number) => {
      blocks.push({ m, y, delay });
      return m;
    };

    // Dimensiones (Y arriba). Bloques grandes; cada capa más angosta que la de abajo.
    const lW = 2.85,
      kW = 2.22,
      aW = 1.92,
      uW = 1.62;
    const lH = 0.4,
      kH = 0.72,
      aH = 1.78,
      uH = 0.6,
      gap = 0.15;
    const mS = 0.42;
    const lY = lH / 2;
    const kY = lH + gap + kH / 2;
    const aY = lH + gap + kH + gap + aH / 2;
    const uY = lH + gap + kH + gap + aH + gap + uH / 2;
    const topY = lH + gap + kH + gap + aH + gap + uH;
    const totalH = topY + 0.06 + mS;

    // Base Laravel: grande y plana, el cimiento sobre el que se monta todo.
    add(slab(lW, lH, lW, lY, 0xef382b, 0.55, labelTexture('Laravel', 'el framework web', '#ef382b', '#ffffff', lW / lH)), lY, 0);
    add(slab(kW, kH, kW, kY, 0x1a1f27, 0.7, labelTexture('Kernel', 'GL · BCMath', '#1a1f27', '#e7ebf1', kW / kH)), kY, 0.16);
    add(
      slab(aW, aH, aW, aY, 0x8f3346, 0.5, labelTexture('Aurora', 'Make · SDK · Runtime', '#8f3346', '#ffffff', aW / aH, true), 0x2a0b11),
      aY,
      0.32,
    );
    add(slab(uW, uH, uW, uY, 0xffffff, 0.85, labelTexture('Tu UI', 'Filament · Nova', '#ffffff', '#3c4655', uW / uH)), uY, 0.48);

    // Cubos de arriba: módulos concretos construidos sobre la plataforma.
    const modules: { t: string; c: number }[] = [
      { t: 'Ventas', c: 0xb8475e },
      { t: 'Inventario', c: 0x3f6588 },
      { t: 'CRM', c: 0x2f4d66 },
      { t: 'Fiscal', c: 0x8f3346 },
      { t: 'Tesorería', c: 0x5a7fa0 },
      { t: 'Diferidos', c: 0xa84258 },
    ];
    const miY = topY + 0.06 + mS / 2;
    const cols = [-0.49, 0, 0.49];
    const rows = [-0.37, 0.37];
    modules.forEach((mi, i) => {
      const tex = labelTexture(mi.t, '', `#${mi.c.toString(16).padStart(6, '0')}`, '#ffffff', 1);
      const m = slab(mS, mS, mS, miY, mi.c, 0.5, tex);
      m.position.x = cols[i % 3];
      m.position.z = rows[Math.floor(i / 3)];
      add(m, miY, 0.6 + i * 0.06);
    });

    // Centrar verticalmente la torre alrededor del origen.
    const groundY = -totalH / 2 + 0.1;
    group.position.y = groundY;

    // Sombra de contacto en el piso.
    const ground = new THREE.Mesh(
      new THREE.PlaneGeometry(30, 30),
      new THREE.ShadowMaterial({ opacity: 0.18 }),
    );
    ground.rotation.x = -Math.PI / 2;
    ground.position.y = groundY;
    ground.receiveShadow = true;
    scene.add(ground);

    // Piso blueprint: grilla técnica con fade radial (eco del hero de Laravel).
    function gridTexture() {
      const g = 1024;
      const c = document.createElement('canvas');
      c.width = c.height = g;
      const x = c.getContext('2d')!;
      x.strokeStyle = 'rgba(26,31,39,0.9)';
      x.lineWidth = 2;
      for (let i = 0; i <= g; i += 64) {
        x.beginPath();
        x.moveTo(i, 0);
        x.lineTo(i, g);
        x.stroke();
        x.beginPath();
        x.moveTo(0, i);
        x.lineTo(g, i);
        x.stroke();
      }
      // fade radial: difumina la grilla en todos los bordes, antes de tocar el borde del viewport.
      x.globalCompositeOperation = 'destination-in';
      const rad = x.createRadialGradient(g / 2, g / 2, g * 0.04, g / 2, g / 2, g * 0.5);
      rad.addColorStop(0, 'rgba(0,0,0,0.5)');
      rad.addColorStop(0.5, 'rgba(0,0,0,0.28)');
      rad.addColorStop(0.8, 'rgba(0,0,0,0.06)');
      rad.addColorStop(1, 'rgba(0,0,0,0)');
      x.fillStyle = rad;
      x.fillRect(0, 0, g, g);
      const t = new THREE.CanvasTexture(c);
      // @ts-ignore
      t.colorSpace = THREE.SRGBColorSpace;
      return t;
    }
    const grid = new THREE.Mesh(
      new THREE.PlaneGeometry(11, 11),
      new THREE.MeshBasicMaterial({ map: gridTexture(), transparent: true, depthWrite: false }),
    );
    grid.rotation.x = -Math.PI / 2;
    grid.position.y = groundY + 0.002;
    scene.add(grid);

    // ── Interacción + animación ────────────────────────────
    let targetX = 0;
    let targetY = 0;
    mount.addEventListener('pointermove', (e) => {
      const r = mount.getBoundingClientRect();
      targetY = ((e.clientX - r.left) / r.width - 0.5) * 0.5;
      targetX = ((e.clientY - r.top) / r.height - 0.5) * 0.28;
    });
    mount.addEventListener('pointerleave', () => {
      targetX = 0;
      targetY = 0;
    });

    const ro = new ResizeObserver(() => {
      setSize();
      if (reduce) renderer.render(scene, camera);
    });
    ro.observe(mount);

    if (reduce) {
      renderer.render(scene, camera);
      return;
    }

    // Construcción al cargar: cada bloque cae desde arriba y encaja, de abajo a arriba.
    for (const b of blocks) {
      b.m.visible = false;
      b.m.scale.setScalar(0.0001);
    }
    const blockDur = 0.55;
    const buildEnd = Math.max(...blocks.map((b) => b.delay)) + blockDur;
    const easeOutBack = (p: number) => {
      const c1 = 1.70158;
      const c3 = c1 + 1;
      return 1 + c3 * Math.pow(p - 1, 3) + c1 * Math.pow(p - 1, 2);
    };

    const start = performance.now();
    function frame(now: number) {
      const t = (now - start) / 1000;

      for (const b of blocks) {
        const p = Math.min(Math.max((t - b.delay) / blockDur, 0), 1);
        if (p <= 0) {
          b.m.visible = false;
          continue;
        }
        b.m.visible = true;
        const e = easeOutBack(p);
        b.m.position.y = b.y + (1 - e) * 1.4; // cae desde arriba, con snap
        b.m.scale.setScalar(0.6 + 0.4 * Math.min(p * 1.4, 1));
      }

      group.rotation.y += (targetY + Math.sin(t * 0.4) * 0.06 - group.rotation.y) * 0.05;
      group.rotation.x += (targetX - group.rotation.x) * 0.05;
      group.position.y = groundY + (t > buildEnd ? Math.sin((t - buildEnd) * 0.9) * 0.05 : 0);

      renderer.render(scene, camera);
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
</script>

<style>
  .iso3d {
    position: relative;
    width: 100%;
    height: 480px;
    touch-action: pan-y;
  }
  .iso3d canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
</style>
