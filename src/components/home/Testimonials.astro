---
import Container from '../Container.astro';

const testimonials = [
  {
    quote:
      'We shut down our gateway, our cache cluster, and the on-call rotation that babysat them. p99 went from 180ms to 46ms in the first week.',
    name: 'Maya Lindqvist',
    role: 'Platform Lead, Driftbase',
    initials: 'ML',
    avatar: 'border-brand/25 bg-brand/15 text-brand-bright',
  },
  {
    quote:
      'The tracing is the feature. A query that had been slow for months showed up on the first waterfall — we fixed it in an afternoon.',
    name: 'Diego Fuentes',
    role: 'Staff Engineer, Hexlayer',
    initials: 'DF',
    avatar: 'border-accent/25 bg-accent/10 text-accent',
  },
  {
    quote:
      'Preview environments changed how we review. Every pull request ships with a URL, so reviewers test the API instead of reading diffs.',
    name: 'Anika Mehta',
    role: 'CTO, Corecast',
    initials: 'AM',
    avatar: 'border-line-2 bg-panel-2 text-fg-2',
  },
];
---

<section aria-label="What customers say">
  <Container class="py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Customers</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        Teams that switched, stayed
      </h2>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {
        testimonials.map(({ quote, name, role, initials, avatar }) => (
          <figure class="glass flex flex-col justify-between rounded-xl p-6 transition-colors hover:border-line-2">
            <blockquote class="text-[15px] leading-relaxed text-fg-2">
              <p>“{quote}”</p>
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3 border-t border-line pt-5">
              <span
                aria-hidden="true"
                class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-full border text-sm font-medium ${avatar}`}
              >
                {initials}
              </span>
              <span>
                <span class="block text-sm font-medium text-fg">{name}</span>
                <span class="block text-[13px] text-fg-3">{role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </Container>
</section>
