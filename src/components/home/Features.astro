---
import Container from '../Container.astro';

const regions = [
  { x: 60, y: 96, label: 'sfo · 31ms' },
  { x: 150, y: 74, label: 'iad · 24ms' },
  { x: 235, y: 104, label: 'gru · 48ms' },
  { x: 320, y: 68, label: 'fra · 9ms' },
  { x: 415, y: 86, label: 'bom · 37ms' },
  { x: 505, y: 102, label: 'syd · 52ms' },
];

const sparkPoints =
  '0,54 40,60 80,56 120,66 160,60 200,72 240,66 280,78 320,72 360,84 400,78 440,90 480,84 520,96 556,92';
---

<section id="features" class="scroll-mt-20">
  <Container class="py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Platform</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        Everything an API platform should handle
      </h2>
      <p class="mt-4 max-w-xl text-fg-2">
        Aurora Labs owns the run-and-operate layer — deploys, caching, tracing, rollbacks — so your
        repository stays application code.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
      <!-- Global deploys (wide, region map) -->
      <article
        class="group rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2 sm:col-span-2 lg:col-span-4"
      >
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-panel-2 text-brand-bright"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="10" cy="10" r="7.5"></circle>
            <path d="M2.5 10h15M10 2.5c2.4 2.6 2.4 12.4 0 15-2.4-2.6-2.4-12.4 0-15Z"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-[15px] font-semibold text-fg">One command, 28 regions</h3>
        <p class="mt-2 max-w-md text-sm leading-relaxed text-fg-2">
          <code class="font-mono text-[13px] text-fg">aurora deploy</code> ships your API to every
          region at once. Traffic routes to the nearest healthy edge — 42ms p99 worldwide.
        </p>

        <svg
          viewBox="0 0 560 150"
          class="mt-6 w-full"
          role="img"
          aria-label="Six Aurora Labs regions with median latency, from 9 milliseconds in Frankfurt to 52 in Sydney"
        >
          <defs>
            <pattern id="region-dotgrid" width="16" height="16" patternUnits="userSpaceOnUse">
              <circle cx="1" cy="1" r="1" class="fill-fg-3/20"></circle>
            </pattern>
          </defs>
          <rect width="560" height="150" fill="url(#region-dotgrid)"></rect>
          <path
            d="M60 96 L150 74 L235 104 L320 68 L415 86 L505 102"
            fill="none"
            class="stroke-line-2"
            stroke-dasharray="2 6"
            stroke-linecap="round"></path>
          {
            regions.map(({ x, y, label }) => (
              <g>
                <circle cx={x} cy={y} r="8" class="fill-accent/15" />
                <circle cx={x} cy={y} r="2.5" class="fill-accent" />
                <text x={x} y={y + 22} text-anchor="middle" font-size="10" class="fill-fg-3 font-mono">
                  {label}
                </text>
              </g>
            ))
          }
        </svg>
      </article>

      <!-- Edge caching -->
      <article
        class="group flex flex-col rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2 lg:col-span-2"
      >
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-panel-2 text-brand-bright"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 2.5 2.5 6.25 10 10l7.5-3.75L10 2.5Z"></path>
            <path d="m2.5 10.25 7.5 3.75 7.5-3.75"></path>
            <path d="m2.5 14.25 7.5 3.75 7.5-3.75"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-[15px] font-semibold text-fg">Edge caching with SWR</h3>
        <p class="mt-2 text-sm leading-relaxed text-fg-2">
          <code class="font-mono text-[13px] text-fg">cache.swr()</code> serves stale instantly and
          revalidates in the background. Hits return in 6ms at the median, no invalidation service
          to run.
        </p>

        <div class="mt-auto pt-6">
          <div class="divide-y divide-line rounded-lg border border-line font-mono text-[11px]">
            <div class="flex items-center gap-2 px-3 py-2">
              <span class="w-10 text-accent">hit</span>
              <span class="text-fg-3" aria-hidden="true">&rarr;</span>
              <span class="text-fg-3">edge</span>
              <span class="ml-auto text-fg-2">6ms</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2">
              <span class="w-10 text-brand-bright">stale</span>
              <span class="text-fg-3" aria-hidden="true">&rarr;</span>
              <span class="text-fg-3">edge, revalidate</span>
              <span class="ml-auto text-fg-2">6ms</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2">
              <span class="w-10 text-fg-2">miss</span>
              <span class="text-fg-3" aria-hidden="true">&rarr;</span>
              <span class="text-fg-3">origin</span>
              <span class="ml-auto text-fg-2">41ms</span>
            </div>
          </div>
        </div>
      </article>

      <!-- Zero-config previews -->
      <article
        class="group flex flex-col rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2 lg:col-span-2"
      >
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-panel-2 text-brand-bright"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="5.5" cy="4.5" r="2"></circle>
            <circle cx="5.5" cy="15.5" r="2"></circle>
            <circle cx="14.5" cy="6.5" r="2"></circle>
            <path d="M5.5 6.5v7M14.5 8.5c0 3.2-3.4 4-6.2 4.4"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-[15px] font-semibold text-fg">Zero-config previews</h3>
        <p class="mt-2 text-sm leading-relaxed text-fg-2">
          Every pull request gets an isolated environment with its own URL. Live in about 10
          seconds, deleted on merge.
        </p>

        <div class="mt-auto flex flex-col items-start gap-2 pt-6 font-mono text-[11px]">
          <span class="flex items-center gap-2 rounded-full border border-line px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
            <span class="text-fg-2">pr-214.auroralabs.dev</span>
            <span class="text-fg-3">live in 9s</span>
          </span>
          <span class="flex items-center gap-2 rounded-full border border-line px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
            <span class="text-fg-2">pr-213.auroralabs.dev</span>
            <span class="text-fg-3">live in 11s</span>
          </span>
          <span class="flex items-center gap-2 rounded-full border border-line px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-fg-3/50" aria-hidden="true"></span>
            <span class="text-fg-3">pr-209.auroralabs.dev</span>
            <span class="text-fg-3">merged, removed</span>
          </span>
        </div>
      </article>

      <!-- Observability (wide, latency sparkline) -->
      <article
        class="group rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2 sm:col-span-2 lg:col-span-4"
      >
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-panel-2 text-brand-bright"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2.5 10h3L8 4l4 12 2.5-6h3"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-[15px] font-semibold text-fg">Request-level tracing</h3>
        <p class="mt-2 max-w-md text-sm leading-relaxed text-fg-2">
          Every request is traced end to end — middleware, cache, database. No agents to
          install, no sampling surprises.
        </p>

        <svg
          viewBox="0 0 560 130"
          class="mt-6 w-full"
          role="img"
          aria-label="p99 latency over the last 24 hours, trending down and staying under the 50 millisecond budget"
        >
          <defs>
            <linearGradient id="latency-fill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.16"></stop>
              <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"></stop>
            </linearGradient>
          </defs>
          <g class="stroke-line">
            <line x1="0" y1="30" x2="560" y2="30"></line>
            <line x1="0" y1="70" x2="560" y2="70"></line>
            <line x1="0" y1="110" x2="560" y2="110"></line>
          </g>
          <polygon points={`${sparkPoints} 556,130 0,130`} fill="url(#latency-fill)"></polygon>
          <polyline
            points={sparkPoints}
            fill="none"
            class="stroke-accent"
            stroke-width="1.5"
            stroke-linejoin="round"></polyline>
          <line
            x1="0"
            y1="38"
            x2="560"
            y2="38"
            class="stroke-brand-bright/60"
            stroke-dasharray="4 4"></line>
          <text x="554" y="30" text-anchor="end" font-size="10" class="fill-fg-3 font-mono">
            p99 budget · 50ms
          </text>
          <text x="6" y="124" font-size="10" class="fill-fg-3 font-mono">p99 · last 24h</text>
          <circle cx="556" cy="92" r="3" class="fill-accent"></circle>
        </svg>
      </article>

      <!-- Type-safe SDK -->
      <article
        class="group rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2 lg:col-span-3"
      >
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-panel-2 text-brand-bright"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 5.5 2.5 10 7 14.5M13 5.5 17.5 10 13 14.5"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-[15px] font-semibold text-fg">A type-safe SDK</h3>
        <p class="mt-2 text-sm leading-relaxed text-fg-2">
          Routes, params, and responses are fully inferred in
          <code class="font-mono text-[13px] text-fg">@auroralabs/sdk</code>. If it compiles, the
          contract holds — across every handler and every consumer.
        </p>
      </article>

      <!-- Instant rollbacks -->
      <article
        class="group rounded-xl border border-line bg-panel p-6 transition-colors hover:border-line-2 hover:bg-panel-2 lg:col-span-3"
      >
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-panel-2 text-brand-bright"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 4v4.5h4.5"></path>
            <path d="M3.8 12.4a7 7 0 1 0 .3-5.6L3 8.5"></path>
          </svg>
        </div>
        <h3 class="mt-4 text-[15px] font-semibold text-fg">Instant rollbacks</h3>
        <p class="mt-2 text-sm leading-relaxed text-fg-2">
          Every deploy is immutable. Pin traffic to any previous version in under 10 seconds
          globally — no rebuild, no redeploy, no incident channel archaeology.
        </p>
      </article>
    </div>
  </Container>
</section>
