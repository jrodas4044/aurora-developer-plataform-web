---
import Container from '../Container.astro';
import WindowDots from '../WindowDots.astro';

// Fitness-function suite — start/width drive the staggered bars, not time.
const spans = [
  { label: 'Arch suite', start: 0, width: 100, tone: 'root', ms: 'pass' },
  { label: 'PlatformContractsFreezeTest', start: 4, width: 22, tone: 'module', ms: 'pass' },
  { label: 'PackageBoundaryTest', start: 10, width: 30, tone: 'module', ms: 'pass' },
  { label: 'ModuleManifestComplianceTest', start: 16, width: 34, tone: 'verification', ms: 'pass' },
  { label: 'Accounting depends on no module', start: 24, width: 40, tone: 'verification', ms: 'pass' },
  { label: 'Dinero = BCMath, nunca float', start: 30, width: 46, tone: 'verification', ms: 'pass' },
  { label: 'pint --test', start: 40, width: 30, tone: 'neutral', ms: 'pass' },
] as const;

const tones: Record<(typeof spans)[number]['tone'], string> = {
  root: 'bg-gradient-to-r from-brand to-accent',
  module: 'bg-accent/60',
  verification: 'bg-brand-bright/70',
  neutral: 'bg-fg-3/40',
};

const ticks = ['frontera', 'contrato', 'invariante', 'ADR'];

const logs = [
  { time: 'build', level: 'PASS', text: 'arch.boundary Aurora\\Payroll → solo contratos SDK' },
  { time: 'build', level: 'PASS', text: 'payroll no importa App\\Modules\\Accounting' },
  { time: 'build', level: 'PASS', text: 'manifest.compliance wiring == declarado' },
  { time: 'build', level: 'WARN', text: 'platform-contracts: firma congelada (freeze test)' },
  { time: 'build', level: 'PASS', text: 'money.bcmath sin acumulación float' },
  { time: 'build', level: 'PASS', text: 'fitness suite ok · 0 violaciones' },
] as const;

const gridlines =
  'relative h-7 [background-image:linear-gradient(90deg,rgb(255_255_255/0.05)_1px,transparent_1px)] [background-size:25%_100%]';
---

<section id="verificacion" class="scroll-mt-20 border-y border-line bg-ink-2">
  <Container class="py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Verificación</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        La arquitectura se verifica, no se confía
      </h2>
      <p class="mt-4 max-w-xl text-fg-2">
        Las fronteras entre módulos, las decisiones de los ADRs y los invariantes de negocio se
        comprueban en cada build. Si un módulo importa la implementación de otro o rompe una
        invariante financiera, el build falla — antes de llegar a producción.
      </p>
    </div>

    <!-- Verification panel -->
    <div class="mt-12 overflow-hidden rounded-xl border border-line bg-ink">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 border-b border-line px-4 py-3">
        <WindowDots />
        <span class="ml-2 font-mono text-xs text-fg-3">fitness suite · Arch</span>
        <span class="ml-auto flex items-center gap-2 font-mono text-[11px]">
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-fg-2">packages/aurora/payroll</span>
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-accent">pass</span>
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-fg-2">0 violaciones</span>
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-fg-3">CI</span>
        </span>
      </div>

      <div class="grid lg:grid-cols-[1.6fr_1fr]">
        <!-- Waterfall -->
        <div class="min-w-0 p-4 sm:p-5">
          <h3 class="sr-only">Suite de fitness functions</h3>
          <div class="grid grid-cols-[96px_1fr] items-center gap-x-3 sm:grid-cols-[130px_1fr_44px]">
            <!-- axis row -->
            <span aria-hidden="true"></span>
            <div class="relative h-5" aria-hidden="true">
              {
                ticks.map((tick, i) => (
                  <span
                    class="absolute top-0 font-mono text-[10px] text-fg-3"
                    style={`left:${i * 25}%`}
                  >
                    {tick}
                  </span>
                ))
              }
            </div>
            <span class="hidden sm:block" aria-hidden="true"></span>

            {
              spans.map(({ label, start, width, tone, ms }) => (
                <>
                  <span class="truncate py-1 font-mono text-[11px] text-fg-3">{label}</span>
                  <div class={gridlines}>
                    <span
                      class={`absolute top-1/2 h-2.5 min-w-[3px] -translate-y-1/2 rounded-[3px] ${tones[tone]}`}
                      style={`left:${start}%;width:${width}%`}
                    />
                  </div>
                  <span class="hidden text-right font-mono text-[11px] text-accent sm:block">{ms}</span>
                </>
              ))
            }
          </div>
        </div>

        <!-- Audit stream -->
        <div class="min-w-0 border-t border-line bg-ink-2/60 lg:border-l lg:border-t-0">
          <div class="flex items-center gap-2 border-b border-line px-4 py-2.5">
            <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-accent motion-reduce:animate-none"></span>
            <span class="font-mono text-xs text-fg-3">auditoría — arquitectura</span>
          </div>
          <ul class="space-y-1.5 overflow-x-auto p-4 font-mono text-[11px] leading-relaxed">
            {
              logs.map(({ time, level, text }) => (
                <li class="whitespace-nowrap">
                  <span class="text-fg-3">{time}</span>
                  <span class={level === 'WARN' ? 'text-brand-bright' : 'text-accent'}> {level}</span>
                  <span class="text-fg-2"> {text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <p class="mt-5 text-center font-mono text-[13px] text-fg-3 sm:text-left">
      Las fitness functions corren en cada build, no como un paso opcional — un cambio que rompe una
      frontera o un invariante falla ruidoso en CI, no en silencio en producción.
    </p>
  </Container>
</section>
