---
import Container from '../Container.astro';
import WindowDots from '../WindowDots.astro';

// Trace waterfall for POST /checkout — offsets and widths are % of the 87ms window.
const spans = [
  { label: 'POST /checkout', start: 0, width: 100, tone: 'root', ms: '87ms' },
  { label: 'auth.bearer', start: 2, width: 5, tone: 'edge', ms: '4ms' },
  { label: 'rateLimit', start: 7, width: 2, tone: 'edge', ms: '1ms' },
  { label: 'db.orders.create', start: 10, width: 26, tone: 'db', ms: '23ms' },
  { label: 'stripe.charge', start: 36, width: 47, tone: 'external', ms: '41ms' },
  { label: 'cache.purge', start: 83, width: 3, tone: 'edge', ms: '2ms' },
  { label: 'serialize', start: 86, width: 2, tone: 'edge', ms: '1ms' },
] as const;

const tones: Record<(typeof spans)[number]['tone'], string> = {
  root: 'bg-gradient-to-r from-brand to-accent',
  edge: 'bg-accent/60',
  db: 'bg-brand-bright/70',
  external: 'bg-fg-3/40',
};

const ticks = ['0ms', '22ms', '44ms', '65ms'];

const logs = [
  { time: '12:04:31.118', level: 'INFO', text: 'request.start method=POST path=/checkout' },
  { time: '12:04:31.121', level: 'INFO', text: 'auth.ok sub=usr_84h2' },
  { time: '12:04:31.152', level: 'INFO', text: 'db.insert table=orders rows=1' },
  { time: '12:04:31.190', level: 'WARN', text: 'stripe.retry attempt=2 backoff=120ms' },
  { time: '12:04:31.203', level: 'INFO', text: 'cache.purge key=orders:usr_84h2' },
  { time: '12:04:31.205', level: 'INFO', text: 'request.end status=200 dur=87ms' },
] as const;

const gridlines =
  'relative h-7 [background-image:linear-gradient(90deg,rgb(255_255_255/0.05)_1px,transparent_1px)] [background-size:25%_100%]';
---

<section class="border-y border-line bg-ink-2">
  <Container class="py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Observability</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        See every request, end to end
      </h2>
      <p class="mt-4 max-w-xl text-fg-2">
        Aurora Labs traces each request through middleware, cache, and database — and streams structured
        logs alongside. When something is slow, you know which span, in which region, and why.
      </p>
    </div>

    <!-- Trace panel -->
    <div class="mt-12 overflow-hidden rounded-xl border border-line bg-ink">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 border-b border-line px-4 py-3">
        <WindowDots />
        <span class="ml-2 font-mono text-xs text-fg-3">trace 01J9JD4QK7</span>
        <span class="ml-auto flex items-center gap-2 font-mono text-[11px]">
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-fg-2">POST /checkout</span>
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-accent">200</span>
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-fg-2">87ms</span>
          <span class="rounded-md border border-line bg-panel px-2 py-0.5 text-fg-3">fra</span>
        </span>
      </div>

      <div class="grid lg:grid-cols-[1.6fr_1fr]">
        <!-- Waterfall -->
        <div class="min-w-0 p-4 sm:p-5">
          <h3 class="sr-only">Trace waterfall</h3>
          <div class="grid grid-cols-[96px_1fr] items-center gap-x-3 sm:grid-cols-[130px_1fr_44px]">
            <!-- axis row -->
            <span aria-hidden="true"></span>
            <div class="relative h-5" aria-hidden="true">
              {
                ticks.map((tick, i) => (
                  <span
                    class="absolute top-0 font-mono text-[10px] text-fg-3"
                    style={`left:${i * 25}%`}
                  >
                    {tick}
                  </span>
                ))
              }
            </div>
            <span class="hidden sm:block" aria-hidden="true"></span>

            {
              spans.map(({ label, start, width, tone, ms }) => (
                <>
                  <span class="truncate py-1 font-mono text-[11px] text-fg-3">{label}</span>
                  <div class={gridlines}>
                    <span
                      class={`absolute top-1/2 h-2.5 min-w-[3px] -translate-y-1/2 rounded-[3px] ${tones[tone]}`}
                      style={`left:${start}%;width:${width}%`}
                    />
                  </div>
                  <span class="hidden text-right font-mono text-[11px] text-fg-3 sm:block">{ms}</span>
                </>
              ))
            }
          </div>
        </div>

        <!-- Log stream -->
        <div class="min-w-0 border-t border-line bg-ink-2/60 lg:border-l lg:border-t-0">
          <div class="flex items-center gap-2 border-b border-line px-4 py-2.5">
            <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-accent motion-reduce:animate-none"></span>
            <span class="font-mono text-xs text-fg-3">logs — streaming</span>
          </div>
          <ul class="space-y-1.5 overflow-x-auto p-4 font-mono text-[11px] leading-relaxed">
            {
              logs.map(({ time, level, text }) => (
                <li class="whitespace-nowrap">
                  <span class="text-fg-3">{time}</span>
                  <span class={level === 'WARN' ? 'text-brand-bright' : 'text-accent'}> {level}</span>
                  <span class="text-fg-2"> {text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <p class="mt-5 text-center font-mono text-[13px] text-fg-3 sm:text-left">
      Tracing is on by default for every Pro deploy — no agent, no sidecar, no sampling config.
    </p>
  </Container>
</section>
