---
import { Code } from 'astro:components';
import codeTheme from '@shikijs/themes/catppuccin-mocha';
import Container from '../Container.astro';

const manifestCode = `module: payroll
namespace: Aurora\\Payroll
target: package

models:
  Payslip:
    fields:
      employee: { type: party_reference }
      gross:    { type: money }
      net:      { type: money }

posting:
  source: auto_payslip
  determinations: [wages_expense, withholdings_payable]`;

const contractCode = `<?php

namespace Aurora\\Platform\\Contracts\\Posting;

/**
 * El host ejecuta el asiento; el módulo solo provee los datos.
 * El satélite jamás importa el kernel contable.
 */
interface CreatesJournalEntries
{
    public function toJournalEntry(): JournalEntryData;
}`;

const runtimeCode = `<?php

namespace Aurora\\Payroll;

use Aurora\\Platform\\Support\\ModuleRegistry;
use Illuminate\\Support\\ServiceProvider;

final class PayrollServiceProvider extends ServiceProvider
{
    public function boot(ModuleRegistry $registry): void
    {
        // Auto-descubierto: el runtime registra el módulo
        // y lo cablea a multiempresa + onboarding.
        $registry->register(new PayrollModuleManifest());
    }
}`;

const bullets = [
  'El manifiesto declara identidad, modelos, posting y permisos en un solo contrato.',
  'aurora:make-module genera el módulo ya cableado contra los contratos del SDK.',
  'El runtime lo descubre y registra — multiempresa y onboarding incluidos.',
];
---

<section id="loop" class="scroll-mt-20 overflow-hidden">
  <Container class="py-20 sm:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">El loop</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
          Del manifiesto al módulo verificado
        </h2>
        <p class="mt-4 max-w-xl text-fg-2">
          El ciclo de Aurora es el mismo para un módulo de facturación, de inventario o de nómina:
          se declara el contrato, se genera el módulo, depende del SDK y el runtime lo registra. Sin
          andamiaje escrito a mano.
        </p>

        <ul class="mt-8 space-y-4">
          {
            bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-fg-2">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 18 18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="mt-0.5 shrink-0 text-accent"
                  aria-hidden="true"
                >
                  <circle cx="9" cy="9" r="7.5" class="opacity-40" />
                  <path d="m5.75 9.25 2.25 2.25 4.25-4.75" />
                </svg>
                {bullet}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="glass overflow-hidden rounded-xl" data-tabs>
        <div class="flex items-center justify-between border-b border-line pl-2 pr-4">
          <div role="tablist" aria-label="El loop de Aurora" class="flex">
            <button
              type="button"
              id="tab-manifest"
              role="tab"
              aria-selected="true"
              aria-controls="panel-manifest"
              class="-mb-px border-b-2 border-transparent px-3.5 py-3 font-mono text-xs text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand aria-selected:border-brand aria-selected:text-fg"
            >
              module.yaml
            </button>
            <button
              type="button"
              id="tab-contract"
              role="tab"
              aria-selected="false"
              aria-controls="panel-contract"
              tabindex="-1"
              class="-mb-px border-b-2 border-transparent px-3.5 py-3 font-mono text-xs text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand aria-selected:border-brand aria-selected:text-fg"
            >
              CreatesJournalEntries.php
            </button>
            <button
              type="button"
              id="tab-runtime"
              role="tab"
              aria-selected="false"
              aria-controls="panel-runtime"
              tabindex="-1"
              class="-mb-px border-b-2 border-transparent px-3.5 py-3 font-mono text-xs text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand aria-selected:border-brand aria-selected:text-fg"
            >
              PayrollServiceProvider.php
            </button>
          </div>
          <span class="font-mono text-xs text-fg-3">Aurora</span>
        </div>

        <div id="panel-manifest" role="tabpanel" aria-labelledby="tab-manifest" class="p-4">
          <Code code={manifestCode} lang="yaml" theme={codeTheme} />
        </div>
        <div id="panel-contract" role="tabpanel" aria-labelledby="tab-contract" class="p-4" hidden>
          <Code code={contractCode} lang="php" theme={codeTheme} />
        </div>
        <div id="panel-runtime" role="tabpanel" aria-labelledby="tab-runtime" class="p-4" hidden>
          <Code code={runtimeCode} lang="php" theme={codeTheme} />
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  for (const root of document.querySelectorAll<HTMLElement>('[data-tabs]')) {
    const tabs = [...root.querySelectorAll<HTMLButtonElement>('[role="tab"]')];
    const panels = [...root.querySelectorAll<HTMLElement>('[role="tabpanel"]')];

    const select = (index: number, focus = true) => {
      tabs.forEach((tab, i) => {
        const active = i === index;
        tab.setAttribute('aria-selected', String(active));
        tab.tabIndex = active ? 0 : -1;
        panels[i]?.toggleAttribute('hidden', !active);
      });
      if (focus) tabs[index]?.focus();
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(i, false));
      tab.addEventListener('keydown', (event) => {
        const targets: Record<string, number> = {
          ArrowRight: (i + 1) % tabs.length,
          ArrowLeft: (i - 1 + tabs.length) % tabs.length,
          Home: 0,
          End: tabs.length - 1,
        };
        const target = targets[event.key];
        if (target === undefined) return;
        event.preventDefault();
        select(target);
      });
    });
  }
</script>
