---
import { Code } from 'astro:components';
import codeTheme from '@shikijs/themes/catppuccin-mocha';
import Container from '../Container.astro';

const cacheCode = `import { aurora } from '@auroralabs/sdk';

export const api = aurora.app();

api.get('/products', async ({ cache }) => {
  const products = await cache.swr('products', fetchProducts, {
    ttl: 60,
    stale: 300,
  });
  return Response.json(products);
});`;

const middlewareCode = `import { aurora } from '@auroralabs/sdk';

export const api = aurora.app();

api.use(async (ctx, next) => {
  const auth = ctx.request.headers.get('authorization');
  if (!auth?.startsWith('Bearer ')) {
    return new Response('unauthorized', { status: 401 });
  }
  ctx.trace.set('auth.scheme', 'bearer');
  return next();
});`;

const bullets = [
  'Stale-while-revalidate in one call — no invalidation service to operate',
  'Middleware short-circuits at the edge, before your handler is invoked',
  'Full TypeScript inference from route params to response body',
];
---

<section class="overflow-hidden">
  <Container class="py-20 sm:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Developer experience</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
          Infrastructure that reads like application code
        </h2>
        <p class="mt-4 max-w-xl text-fg-2">
          Caching and auth are function calls, not config files. Declare them next
          to the route they protect, and Aurora Labs runs them at the edge in all 28 regions.
        </p>

        <ul class="mt-8 space-y-4">
          {
            bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-fg-2">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 18 18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="mt-0.5 shrink-0 text-accent"
                  aria-hidden="true"
                >
                  <circle cx="9" cy="9" r="7.5" class="opacity-40" />
                  <path d="m5.75 9.25 2.25 2.25 4.25-4.75" />
                </svg>
                {bullet}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="glass overflow-hidden rounded-xl" data-tabs>
        <div class="flex items-center justify-between border-b border-line pl-2 pr-4">
          <div role="tablist" aria-label="Code examples" class="flex">
            <button
              type="button"
              id="tab-cache"
              role="tab"
              aria-selected="true"
              aria-controls="panel-cache"
              class="-mb-px border-b-2 border-transparent px-3.5 py-3 font-mono text-xs text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand aria-selected:border-brand aria-selected:text-fg"
            >
              cache.ts
            </button>
            <button
              type="button"
              id="tab-middleware"
              role="tab"
              aria-selected="false"
              aria-controls="panel-middleware"
              tabindex="-1"
              class="-mb-px border-b-2 border-transparent px-3.5 py-3 font-mono text-xs text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand aria-selected:border-brand aria-selected:text-fg"
            >
              middleware.ts
            </button>
          </div>
          <span class="font-mono text-xs text-fg-3">TypeScript</span>
        </div>

        <div id="panel-cache" role="tabpanel" aria-labelledby="tab-cache" class="p-4">
          <Code code={cacheCode} lang="ts" theme={codeTheme} />
        </div>
        <div id="panel-middleware" role="tabpanel" aria-labelledby="tab-middleware" class="p-4" hidden>
          <Code code={middlewareCode} lang="ts" theme={codeTheme} />
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  for (const root of document.querySelectorAll<HTMLElement>('[data-tabs]')) {
    const tabs = [...root.querySelectorAll<HTMLButtonElement>('[role="tab"]')];
    const panels = [...root.querySelectorAll<HTMLElement>('[role="tabpanel"]')];

    const select = (index: number, focus = true) => {
      tabs.forEach((tab, i) => {
        const active = i === index;
        tab.setAttribute('aria-selected', String(active));
        tab.tabIndex = active ? 0 : -1;
        panels[i]?.toggleAttribute('hidden', !active);
      });
      if (focus) tabs[index]?.focus();
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(i, false));
      tab.addEventListener('keydown', (event) => {
        const targets: Record<string, number> = {
          ArrowRight: (i + 1) % tabs.length,
          ArrowLeft: (i - 1 + tabs.length) % tabs.length,
          Home: 0,
          End: tabs.length - 1,
        };
        const target = targets[event.key];
        if (target === undefined) return;
        event.preventDefault();
        select(target);
      });
    });
  }
</script>
