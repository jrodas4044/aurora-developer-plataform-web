---
import { Code } from 'astro:components';
import codeTheme from '@shikijs/themes/catppuccin-mocha';
import Button from '../Button.astro';
import WindowDots from '../WindowDots.astro';
import Container from '../Container.astro';
import Glow from '../Glow.astro';

const heroCode = `import { aurora } from '@auroralabs/sdk';

export const api = aurora.app({ region: 'global' });

api.get('/users/:id', async ({ params, cache }) => {
  const user = await cache.swr(\`user:\${params.id}\`, () =>
    db.users.find(params.id),
  );
  return Response.json(user);
});`;
---

<section class="relative overflow-hidden">
  <Glow class="left-1/2 top-[-180px] h-[480px] w-[820px] -translate-x-1/2" />

  <!-- Faint grid backdrop -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 [background-image:linear-gradient(rgb(255_255_255/0.025)_1px,transparent_1px),linear-gradient(90deg,rgb(255_255_255/0.025)_1px,transparent_1px)] [background-size:56px_56px] [mask-image:radial-gradient(ellipse_at_top,black_30%,transparent_75%)]"
  >
  </div>

  <Container class="relative pb-24 pt-20 sm:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <a
        href="/blog/aurora-2-0-edge-caching-ga/"
        class="glass inline-flex items-center gap-2 rounded-full px-3.5 py-1.5 text-[13px] text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_8px_rgb(34_211_238/0.8)]"></span>
        Aurora Labs 2.0 — edge caching is now GA
        <span aria-hidden="true" class="text-fg-3">→</span>
      </a>

      <h1 class="mt-6 text-balance text-5xl font-semibold leading-[1.05] tracking-tight sm:text-6xl">
        Ship your API in minutes, <span class="text-gradient">not sprints</span>
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">
        Aurora Labs gives your team a production-grade API platform — global deploys, built-in caching,
        and observability that explains itself. No YAML. No ops rotation.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <Button href="/blog/aurora-2-0-edge-caching-ga/" size="lg">See what's new in 2.0</Button>
        <Button href="/blog/" variant="secondary" size="lg">Read the blog</Button>
      </div>

      <p class="mt-5 font-mono text-[13px] text-fg-2">
        <span class="select-none text-fg-3">$</span> npm install @auroralabs/sdk
      </p>
    </div>

    <!-- Code panel -->
    <div class="relative mx-auto mt-16 max-w-4xl">
      <div class="glass relative grid overflow-hidden rounded-xl shadow-2xl shadow-black/50 md:grid-cols-[1.5fr_1fr]">
        <!-- Editor pane -->
        <div class="min-w-0 border-b border-line md:border-b-0 md:border-r">
          <div class="flex items-center gap-2 border-b border-line px-4 py-3">
            <WindowDots />
            <span class="ml-3 font-mono text-xs text-fg-3">api/index.ts</span>
          </div>
          <div class="overflow-x-auto p-4 text-left">
            <Code code={heroCode} lang="ts" theme={codeTheme} />
          </div>
        </div>

        <!-- Terminal pane -->
        <div class="min-w-0 bg-ink-2/60">
          <div class="flex items-center border-b border-line px-4 py-3">
            <span class="font-mono text-xs text-fg-3">terminal</span>
          </div>
          <div class="space-y-2 p-4 text-left font-mono text-[13px] leading-relaxed">
            <p class="text-fg-2"><span class="select-none text-fg-3">$</span> aurora deploy --watch</p>
            <p class="text-fg-3">Compiling api/index.ts…</p>
            <p><span class="text-accent">✓</span> <span class="text-fg-2">Built in 1.2s</span></p>
            <p><span class="text-accent">✓</span> <span class="text-fg-2">Deployed to 28 regions</span></p>
            <p class="pt-1 text-fg-2">
              <span class="text-brand-bright">→</span> https://api.auroralabs.dev
              <span class="text-fg-3">(42ms p99)</span>
            </p>
            <p class="flex items-center gap-2 pt-2 text-fg-3">
              <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-accent motion-reduce:animate-none"></span>
              watching for changes
            </p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
