---
import Button from '../Button.astro';
import Container from '../Container.astro';
import Glow from '../Glow.astro';
---

<section class="relative overflow-hidden border-t border-line">
  <Glow class="left-1/2 top-1/2 h-[420px] w-[760px] -translate-x-1/2 -translate-y-1/2" />

  <Container class="relative py-24 text-center sm:py-32">
    <h2 data-reveal class="mx-auto max-w-2xl text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
      Aurora es la base. Lo que construyas encima, lo <span class="text-gradient">decides tú</span>.
    </h2>
    <p data-reveal style="--rd:.08s" class="mx-auto mt-5 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">
      ERPs, CRMs, nómina, analítica — cualquier software empresarial que requiera consistencia
      operacional, integridad financiera y evolución sostenible. Aurora aporta la plataforma; tú
      aportas el dominio.
    </p>

    <div data-reveal style="--rd:.16s" class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <Button href="/casos-de-uso" size="lg">Ver casos de uso</Button>
      <Button href="/contacto" variant="secondary" size="lg">Hablar con el equipo</Button>
    </div>
  </Container>
</section>
