---
import Button from '../Button.astro';
import Container from '../Container.astro';
import Glow from '../Glow.astro';
---

<section class="relative overflow-hidden border-t border-line">
  <Glow class="left-1/2 top-1/2 h-[420px] w-[760px] -translate-x-1/2 -translate-y-1/2" />

  <Container class="relative py-24 text-center sm:py-32">
    <h2 class="mx-auto max-w-2xl text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
      Aurora es la base. Lo que construya encima, lo <span class="text-gradient">decide usted</span>.
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">
      ERPs, CRMs, nómina, analítica — cualquier software empresarial que requiera consistencia
      operacional, integridad financiera y evolución sostenible. Aurora aporta la plataforma; usted
      aporta el dominio.
    </p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <Button href="/#capacidades" size="lg">Conozca las capacidades</Button>
      <Button href="/#loop" variant="secondary" size="lg">Ver el loop de Aurora</Button>
    </div>
  </Container>
</section>
