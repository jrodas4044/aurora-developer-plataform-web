---
import Container from '../Container.astro';
---

<section class="border-y border-line bg-ink-2/60" aria-label="Customers">
  <Container class="py-14 sm:py-16">
    <p class="text-center font-mono text-xs uppercase tracking-widest text-fg-3">
      Trusted by teams shipping 8B requests/month
    </p>

    <ul
      class="mt-10 grid grid-cols-2 items-center justify-items-center gap-x-10 gap-y-9 sm:grid-cols-3 lg:grid-cols-6"
    >
      <li class="text-fg-3 transition-colors hover:text-fg-2">
        <svg
          width="118"
          height="26"
          viewBox="0 0 118 26"
          class="overflow-visible"
          role="img"
          aria-label="Driftbase"
        >
          <path
            d="M11 4.5 19.5 21h-17L11 4.5Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"></path>
          <text x="30" y="18.5" font-size="15" font-weight="650" letter-spacing="-0.2" fill="currentColor">
            driftbase
          </text>
        </svg>
      </li>

      <li class="text-fg-3 transition-colors hover:text-fg-2">
        <svg
          width="110"
          height="26"
          viewBox="0 0 110 26"
          class="overflow-visible"
          role="img"
          aria-label="Hexlayer"
        >
          <path
            d="M11 3.5l8 4.75v9.5L11 22.5l-8-4.75v-9.5L11 3.5Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"></path>
          <text x="30" y="18.5" font-size="15" font-weight="600" letter-spacing="-0.1" fill="currentColor">
            Hexlayer
          </text>
        </svg>
      </li>

      <li class="text-fg-3 transition-colors hover:text-fg-2">
        <svg
          width="122"
          height="26"
          viewBox="0 0 122 26"
          class="overflow-visible"
          role="img"
          aria-label="Quantis"
        >
          <circle cx="11" cy="13" r="8.5" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
          <circle cx="11" cy="13" r="2.5" fill="currentColor"></circle>
          <text x="30" y="17.5" font-size="13" font-weight="500" letter-spacing="2.5" fill="currentColor">
            QUANTIS
          </text>
        </svg>
      </li>

      <li class="text-fg-3 transition-colors hover:text-fg-2">
        <svg
          width="96"
          height="26"
          viewBox="0 0 96 26"
          class="overflow-visible"
          role="img"
          aria-label="Modulr"
        >
          <rect x="2" y="4" width="8" height="8" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"
          ></rect>
          <rect x="12.5" y="4" width="8" height="8" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"
          ></rect>
          <rect x="2" y="14.5" width="8" height="8" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"
          ></rect>
          <rect x="12.5" y="14.5" width="8" height="8" rx="1.5" fill="currentColor"></rect>
          <text x="30" y="18.5" font-size="15" font-weight="700" letter-spacing="-0.3" fill="currentColor">
            modulr
          </text>
        </svg>
      </li>

      <li class="text-fg-3 transition-colors hover:text-fg-2">
        <svg
          width="108"
          height="26"
          viewBox="0 0 108 26"
          class="overflow-visible"
          role="img"
          aria-label="Corecast"
        >
          <circle cx="6" cy="13" r="2" fill="currentColor"></circle>
          <path
            d="M10.5 8.5a6.5 6.5 0 0 1 0 9"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
          <path
            d="M14 5a11 11 0 0 1 0 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
          <text x="30" y="18.5" font-size="15" font-weight="600" letter-spacing="-0.1" fill="currentColor">
            Corecast
          </text>
        </svg>
      </li>

      <li class="text-fg-3 transition-colors hover:text-fg-2">
        <svg
          width="100"
          height="26"
          viewBox="0 0 100 26"
          class="overflow-visible"
          role="img"
          aria-label="Statline"
        >
          <rect x="2" y="14" width="3" height="8" rx="1" fill="currentColor"></rect>
          <rect x="8" y="9" width="3" height="13" rx="1" fill="currentColor"></rect>
          <rect x="14" y="4" width="3" height="18" rx="1" fill="currentColor"></rect>
          <text x="26" y="18" font-size="13" font-weight="500" fill="currentColor" class="font-mono">
            statline
          </text>
        </svg>
      </li>
    </ul>
  </Container>
</section>
