---
import Button from './Button.astro';
import Container from './Container.astro';
import Logo from './Logo.astro';

const links = [{ label: 'Blog', href: '/blog/' }];
const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-line bg-ink/70 backdrop-blur-xl" data-nav>
  <Container>
    <nav class="flex h-16 items-center justify-between" aria-label="Main">
      <div class="flex items-center gap-10">
        <Logo />
        <ul class="hidden items-center gap-7 md:flex">
          {
            links.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  aria-current={current.startsWith(href) ? 'page' : undefined}
                  class:list={[
                    'text-sm transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand',
                    current.startsWith(href) ? 'text-fg' : 'text-fg-2 hover:text-fg',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="flex items-center gap-3">
        <a
          href="https://github.com/cbetz/pulsar-lite"
          class="hidden text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand sm:block"
          aria-label="GitHub"
        >
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            ></path>
          </svg>
        </a>
        <Button href="/blog/aurora-2-0-edge-caching-ga/" variant="primary" size="sm">
          Get started
        </Button>
        <button
          type="button"
          data-menu-button
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Menu"
          class="group -mr-2 inline-flex h-10 w-10 items-center justify-center rounded-lg text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:outline-brand md:hidden"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            class="group-aria-expanded:hidden"
            aria-hidden="true"
          >
            <path d="M3 5.5h14M3 10h14M3 14.5h14"></path>
          </svg>
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            class="hidden group-aria-expanded:block"
            aria-hidden="true"
          >
            <path d="m5 5 10 10M15 5 5 15"></path>
          </svg>
        </button>
      </div>
    </nav>
  </Container>

  <div
    id="mobile-menu"
    data-menu-panel
    class="invisible absolute inset-x-0 top-full -translate-y-1 border-b border-line bg-ink/95 opacity-0 backdrop-blur-xl transition-[opacity,transform,visibility] duration-200 ease-out data-open:visible data-open:translate-y-0 data-open:opacity-100 motion-reduce:transition-none md:hidden"
  >
    <Container class="py-3">
      <ul>
        {
          links.map(({ label, href }) => (
            <li>
              <a
                href={href}
                aria-current={current.startsWith(href) ? 'page' : undefined}
                class:list={[
                  'flex min-h-11 items-center rounded-lg px-2 text-sm transition-colors focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand',
                  current.startsWith(href) ? 'text-fg' : 'text-fg-2 hover:text-fg',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="mt-2 border-t border-line pt-2">
        <a
          href="https://github.com/cbetz/pulsar-lite"
          class="flex min-h-11 items-center rounded-lg px-2 text-sm text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand"
        >
          GitHub
        </a>
      </div>
    </Container>
  </div>
</header>

<script>
  for (const nav of document.querySelectorAll<HTMLElement>('[data-nav]')) {
    const button = nav.querySelector<HTMLButtonElement>('[data-menu-button]');
    const panel = nav.querySelector<HTMLElement>('[data-menu-panel]');
    if (!button || !panel) continue;

    const isOpen = () => button.getAttribute('aria-expanded') === 'true';

    const setOpen = (open: boolean) => {
      button.setAttribute('aria-expanded', String(open));
      panel.toggleAttribute('data-open', open);
    };

    const close = () => {
      if (!isOpen()) return;
      setOpen(false);
      button.focus();
    };

    button.addEventListener('click', () => setOpen(!isOpen()));

    panel.addEventListener('click', (event) => {
      if (event.target instanceof Element && event.target.closest('a')) close();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });
  }
</script>
