---
// Decorative radial glow. Position with the class prop; parent needs `relative`.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  aria-hidden="true"
  class={`pointer-events-none absolute select-none ${className}`}
  style="background: radial-gradient(ellipse at center, rgb(152 54 74 / 0.34) 0%, rgb(47 77 102 / 0.12) 45%, transparent 70%); filter: blur(48px);"
>
</div>
