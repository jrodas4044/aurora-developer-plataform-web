---
// Decorative radial glow. Position with the class prop; parent needs `relative`.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  aria-hidden="true"
  class={`pointer-events-none absolute select-none ${className}`}
  style="background: radial-gradient(ellipse at center, rgb(139 92 246 / 0.28) 0%, rgb(34 211 238 / 0.10) 45%, transparent 70%); filter: blur(48px);"
>
</div>
