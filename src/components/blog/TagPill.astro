---
interface Props {
  /** Color classes (border/bg/text). Replaces the default quiet
      palette so callers can recolor without specificity fights. */
  class?: string;
}
const { class: colorClasses = 'border-line bg-white/[0.03] text-fg-3' } = Astro.props;
---

<span
  class={`inline-flex items-center rounded-full border px-2.5 py-1 font-mono text-[11px] uppercase tracking-wider ${colorClasses}`}
>
  <slot />
</span>
