---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// Unique per render — the logo is mounted in both Nav and Footer, and
// duplicate SVG gradient ids are invalid HTML.
const gradientId = `logo-grad-${crypto.randomUUID().slice(0, 8)}`;
---

<a href="/" class={`group inline-flex items-center gap-2 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand ${className}`}>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <defs>
      <linearGradient id={gradientId} x1="0" y1="0" x2="24" y2="24">
        <stop offset="0%" stop-color="var(--color-brand-bright)"></stop>
        <stop offset="100%" stop-color="var(--color-accent)"></stop>
      </linearGradient>
    </defs>
    <path
      d="M12 2L14.8 9.2L22 12L14.8 14.8L12 22L9.2 14.8L2 12L9.2 9.2L12 2Z"
      fill={`url(#${gradientId})`}></path>
  </svg>
  <span class="text-[15px] font-semibold tracking-tight text-fg">aurora labs</span>
</a>
