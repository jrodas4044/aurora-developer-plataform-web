---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href="/" class={`group inline-flex items-center focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand ${className}`}>
  <span class="text-[15px] font-semibold tracking-tight text-fg"><span style="color:#8a1c3a">Aurora</span> <span class="font-normal text-fg-3">Platform</span></span>
</a>
