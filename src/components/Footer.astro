---
import Container from './Container.astro';
import Logo from './Logo.astro';

const columns = [
  {
    title: 'Plataforma',
    links: [
      { label: 'Aurora Make', href: '/aurora-make' },
      { label: 'Aurora Platform SDK', href: '/aurora-platform-sdk' },
      { label: 'Aurora Runtime', href: '/aurora-runtime' },
      { label: 'Aurora Architecture', href: '/aurora-architecture' },
    ],
  },
  {
    title: 'Partners',
    links: [
      { label: 'Partners de Desarrollo', href: '/partners-desarrollo' },
      { label: 'Partners de Soluciones', href: '/partners-soluciones' },
    ],
  },
  {
    title: 'Recursos',
    links: [
      { label: 'Cómo funciona', href: '/como-funciona' },
      { label: 'Casos de uso', href: '/casos-de-uso' },
      { label: 'Blog', href: '/blog/' },
    ],
  },
  {
    title: 'Empresa',
    links: [
      { label: 'Fundador', href: '/fundador' },
      { label: 'Contacto', href: '/contacto' },
      { label: 'GitHub', href: 'https://github.com/' },
    ],
  },
];
---

<footer class="border-t border-line bg-ink-2">
  <Container class="py-14">
    <div class="grid gap-10 md:grid-cols-[1.6fr_1fr_1fr_1fr_1fr]">
      <div>
        <Logo />
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-fg-3">
          Plataforma de desarrollo para software empresarial modular, verificable y
          financieramente consistente.
        </p>
      </div>
      {
        columns.map(({ title, links }) => (
          <nav aria-label={title}>
            <p class="text-[13px] font-semibold tracking-wide text-fg">{title}</p>
            <ul class="mt-4 space-y-2.5">
              {links.map(({ label, href }) => (
                <li>
                  <a href={href} class="link-anim text-sm text-fg-2 hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-line pt-6 sm:flex-row sm:items-center">
      <p class="text-[13px] text-fg-3">© {new Date().getFullYear()} Aurora Platform. Todos los derechos reservados.</p>
      <p class="text-[13px] text-fg-3">Enterprise Development Platform</p>
    </div>
  </Container>
</footer>
