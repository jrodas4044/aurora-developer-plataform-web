---
import Container from './Container.astro';
import Logo from './Logo.astro';

const columns = [
  {
    title: 'Plataforma',
    links: [
      { label: 'Capacidades', href: '/#capacidades' },
      { label: 'El loop', href: '/#loop' },
      { label: 'Verificación', href: '/#verificacion' },
    ],
  },
  {
    title: 'Recursos',
    links: [{ label: 'GitHub', href: 'https://github.com/' }],
  },
];
---

<footer class="border-t border-line bg-ink-2">
  <Container class="py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <Logo />
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-fg-3">
          Plataforma de desarrollo para software empresarial modular, verificable y
          financieramente consistente.
        </p>
      </div>
      {
        columns.map(({ title, links }) => (
          <nav aria-label={title}>
            <p class="text-[13px] font-semibold tracking-wide text-fg">{title}</p>
            <ul class="mt-4 space-y-2.5">
              {links.map(({ label, href }) => (
                <li>
                  <a href={href} class="text-sm text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-line pt-6 sm:flex-row sm:items-center">
      <p class="text-[13px] text-fg-3">© {new Date().getFullYear()} Aurora. Todos los derechos reservados.</p>
    </div>
  </Container>
</footer>
